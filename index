// ── AUTENTICAÇÃO (MSAL) ──
function initMsal() {
  SYNC.msal = new msal.PublicClientApplication({
    auth: {
      clientId: GRAPH.clientId,
      authority: `https://login.microsoftonline.com/${GRAPH.tenantId}`,
      redirectUri: GRAPH.redirectUri
    },
    cache: { cacheLocation: 'sessionStorage', storeAuthStateInCookie: false }
  });
}

async function authStart() {
  const gate = document.getElementById('login-gate');
  const status = document.getElementById('login-status');
  try {
    initMsal();
    await SYNC.msal.initialize();
    // Trata redirecionamento se voltou do login
    const redirectResp = await SYNC.msal.handleRedirectPromise();
    let account = redirectResp?.account || SYNC.msal.getAllAccounts()[0];
    if (!account) {
      // Sem conta — faz login interativo
      status.innerHTML = '<span class="login-spinner"></span>A redirecionar para o login Microsoft 365...';
      await SYNC.msal.loginRedirect({ scopes: GRAPH.scopes });
      return; // o browser vai recarregar
    }
    SYNC.msal.setActiveAccount(account);
    SYNC.user = { name: account.name, mail: account.username };
    status.innerHTML = '<span class="login-spinner"></span>A carregar dados do SharePoint...';
    await graphBootstrap();
    // Tudo OK — esconde a gate e mostra a app
    gate.style.display = 'none';
    document.getElementById('app-shell').style.display = 'flex';
    render();
    startSyncTimers();
  } catch (e) {
    showLoginError(e);
  }
}

