async function getToken() {
  const account = SYNC.msal.getActiveAccount();
  if (!account) throw new Error('Sem sessão ativa.');
  try {
    const r = await SYNC.msal.acquireTokenSilent({ scopes: GRAPH.scopes, account });
    return r.accessToken;
  } catch (e) {
    if (e instanceof msal.InteractionRequiredAuthError) {
      await SYNC.msal.acquireTokenRedirect({ scopes: GRAPH.scopes, account });
      throw new Error('A reautenticar...');
    }
    throw e;
  }
}

async function graph(path, opts = {}) {
  const token = await getToken();
  const url = path.startsWith('https://') ? path : `https://graph.microsoft.com/v1.0${path}`;
  const r = await fetch(url, {
    ...opts,
    headers: {
      Authorization: `Bearer ${token}`,
      'Content-Type': 'application/json',
      Accept: 'application/json',
      ...(opts.headers || {})
    }
  });
  if (!r.ok) {
    const body = await r.text();
    throw new Error(`Graph ${r.status}: ${body.slice(0, 200)}`);
  }
  if (r.status === 204) return null;
  return r.json();
}

// ── BOOTSTRAP: descobrir site e listas, mapear campos, ler dados ──
async function graphBootstrap() {
  // 1. Resolver site ID
  const site = await graph(`/sites/${GRAPH.siteHostname}:${GRAPH.sitePath}`);
  SYNC.siteId = site.id;

  // 2. Resolver IDs das listas
  const lists = await graph(`/sites/${SYNC.siteId}/lists?$select=id,name,displayName`);
  const lp = lists.value.find(l => l.displayName === GRAPH.listPessoas || l.name === GRAPH.listPessoas);
  const lpr = lists.value.find(l => l.displayName === GRAPH.listPresencas || l.name === GRAPH.listPresencas);
  if (!lp) throw new Error(`Lista "${GRAPH.listPessoas}" não encontrada no site.`);
  if (!lpr) throw new Error(`Lista "${GRAPH.listPresencas}" não encontrada no site.`);
  SYNC.listPessoasId = lp.id;
  SYNC.listPresencasId = lpr.id;

  // 3. Mapear nomes lógicos → nomes internos dos campos (que podem ter prefixos OData_)
  const cols = await graph(`/sites/${SYNC.siteId}/lists/${SYNC.listPessoasId}/columns?$select=name,displayName`);
  const fm = {};
  const wanted = ['Nome','Empresa','Função','Estado','Capacidades','Notas','Etapa Teste','Início Teste','Notas Teste','PessoaIDLocal'];
  for (const w of wanted) {
    const c = cols.value.find(c => c.displayName === w || c.name === w);
    if (c) fm[w] = c.name;
  }
  // Nome é "Title" por defeito no SharePoint mesmo após renomear o display
  if (!fm['Nome']) fm['Nome'] = 'Title';
  SYNC.fieldMap = fm;

  // 4. Ler dados iniciais
  await graphReload();
  SYNC.status = 'connected';
  SYNC.lastSyncAt = Date.now();
}

// Converte item SharePoint → pessoa local
function spItemToPerson(item) {
  const f = item.fields || {};
  const m = SYNC.fieldMap;
  const capRaw = f[m['Capacidades']] || '';
  const caps = String(capRaw).split(',').map(s => s.trim()).filter(Boolean);
  // ID local: usamos PessoaIDLocal se existir, senão o ID do SP
  const localId = f[m['PessoaIDLocal']] ? Number(f[m['PessoaIDLocal']]) : Number(item.id);
  return {
    id: localId,
    spId: item.id,
    name: f[m['Nome']] || '',
    company: f[m['Empresa']] || 'Timing',
    role: f[m['Função']] || 'Andares',
    status: f[m['Estado']] || 'Ativo',
    caps,
    notes: f[m['Notas']] || '',
    testStep: Number(f[m['Etapa Teste']] || 0),
    testStartDate: f[m['Início Teste']] ? String(f[m['Início Teste']]).slice(0,10) : '',
    testNotes: f[m['Notas Teste']] || ''
  };
}

function personToSpFields(p) {
  const m = SYNC.fieldMap;
  const o = {};
  o[m['Nome']] = p.name;
  if (m['Empresa']) o[m['Empresa']] = p.company;
  if (m['Função']) o[m['Função']] = p.role;
  if (m['Estado']) o[m['Estado']] = p.status;
  if (m['Capacidades']) o[m['Capacidades']] = (p.caps || []).join(', ');
  if (m['Notas']) o[m['Notas']] = p.notes || '';
  if (m['Etapa Teste']) o[m['Etapa Teste']] = Number(p.testStep || 0);
  if (m['Início Teste']) o[m['Início Teste']] = p.testStartDate || null;
  if (m['Notas Teste']) o[m['Notas Teste']] = p.testNotes || '';
  if (m['PessoaIDLocal']) o[m['PessoaIDLocal']] = String(p.id);
  return o;
}

async function graphReload() {
  SYNC.suppressWrite = true;
  try {
    // Pessoas
    let items = [];
    let url = `/sites/${SYNC.siteId}/lists/${SYNC.listPessoasId}/items?$expand=fields&$top=200`;
    while (url) {
      const page = await graph(url);
      items = items.concat(page.value);
      url = page['@odata.nextLink'] || null;
    }
    if (items.length === 0) {
      // Lista vazia: faz seed inicial
      await seedSharePointFromSeed();
      return graphReload();
    }
    const people = items.map(spItemToPerson);
    S.people = people;
    SYNC.spIdByPersonId = {};
    people.forEach(p => { SYNC.spIdByPersonId[p.id] = p.spId; });
    S.nextId = Math.max(0, ...people.map(p => p.id)) + 1;

    // Presenças
    let aItems = [];
    let aUrl = `/sites/${SYNC.siteId}/lists/${SYNC.listPresencasId}/items?$expand=fields&$top=500`;
    while (aUrl) {
      const page = await graph(aUrl);
      aItems = aItems.concat(page.value);
      aUrl = page['@odata.nextLink'] || null;
    }
    const att = {};
    SYNC.attendanceSpIds = {};
    aItems.forEach(it => {
      const key = it.fields?.Title;
      const st = it.fields?.Estado;
      if (key && st) {
        att[key] = st;
        SYNC.attendanceSpIds[key] = it.id;
      }
    });
    S.attendance = att;
    S.hasSaved = true;
    try { localStorage.setItem(LS_KEY, JSON.stringify({people:S.people, attendance:S.attendance, nextId:S.nextId})); } catch(e){}
  } finally {
    SYNC.suppressWrite = false;
  }
}

async function seedSharePointFromSeed() {
  toast('Lista vazia — a importar dados iniciais para SharePoint...', 'warn');
  for (const p of SEED) {
    const fields = personToSpFields(p);
    await graph(`/sites/${SYNC.siteId}/lists/${SYNC.listPessoasId}/items`, {
      method: 'POST',
      body: JSON.stringify({ fields })
    });
  }
  toast('Importação inicial concluída.', 'ok');
}

// ── WRITES (queue dedupada + debounce) ──
function queueWrite(key, fn) {
  if (SYNC.suppressWrite) return;
  SYNC.writeQueue.set(key, fn);
  clearTimeout(SYNC.writeTimer);
  SYNC.writeTimer = setTimeout(flushWrites, SYNC.WRITE_DEBOUNCE_MS);
}

async function flushWrites() {
  if (SYNC.writeQueue.size === 0) return;
  const jobs = Array.from(SYNC.writeQueue.values());
  SYNC.writeQueue.clear();
  SYNC.status = 'syncing'; renderTopbar();
  let errors = 0;
  for (const fn of jobs) {
    try { await fn(); }
    catch (e) { errors++; console.error('Write falhou:', e); }
  }
  SYNC.status = errors ? 'error' : 'connected';
  SYNC.errorMsg = errors ? `${errors} alteração(ões) falharam.` : '';
  SYNC.lastSyncAt = Date.now();
  renderTopbar();
  if (errors) toast(`${errors} alteração(ões) falharam. Verifica a tua ligação.`, 'err');
}

// Dispara write para pessoa (upsert ou delete)
function syncPerson(p, op = 'upsert') {
  if (SYNC.suppressWrite) return;
  if (op === 'delete') {
    const spId = SYNC.spIdByPersonId[p.id];
    if (!spId) return;
    queueWrite(`person:${p.id}`, async () => {
      await graph(`/sites/${SYNC.siteId}/lists/${SYNC.listPessoasId}/items/${spId}`, { method: 'DELETE' });
      delete SYNC.spIdByPersonId[p.id];
    });
    return;
  }
  const spId = SYNC.spIdByPersonId[p.id];
  if (spId) {
    queueWrite(`person:${p.id}`, async () => {
      await graph(`/sites/${SYNC.siteId}/lists/${SYNC.listPessoasId}/items/${spId}/fields`, {
        method: 'PATCH', body: JSON.stringify(personToSpFields(p))
      });
    });
  } else {
    queueWrite(`person:${p.id}`, async () => {
      const r = await graph(`/sites/${SYNC.siteId}/lists/${SYNC.listPessoasId}/items`, {
        method: 'POST', body: JSON.stringify({ fields: personToSpFields(p) })
      });
      SYNC.spIdByPersonId[p.id] = r.id;
    });
  }
}

// Dispara write para presença
function syncAttendance(personId, date, value) {
  if (SYNC.suppressWrite) return;
  const key = `${personId}_${date}`;
  const spId = SYNC.attendanceSpIds[key];
  if (!value) {
    if (!spId) return;
    queueWrite(`att:${key}`, async () => {
      await graph(`/sites/${SYNC.siteId}/lists/${SYNC.listPresencasId}/items/${spId}`, { method: 'DELETE' });
      delete SYNC.attendanceSpIds[key];
    });
  } else if (spId) {
    queueWrite(`att:${key}`, async () => {
      await graph(`/sites/${SYNC.siteId}/lists/${SYNC.listPresencasId}/items/${spId}/fields`, {
        method: 'PATCH', body: JSON.stringify({ Estado: value })
      });
    });
  } else {
    queueWrite(`att:${key}`, async () => {
      const r = await graph(`/sites/${SYNC.siteId}/lists/${SYNC.listPresencasId}/items`, {
        method: 'POST', body: JSON.stringify({ fields: { Title: key, Data: date, Estado: value } })
      });
      SYNC.attendanceSpIds[key] = r.id;
    });
  }
}

