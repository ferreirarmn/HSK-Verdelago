// ── POLLING ──
function startSyncTimers() {
  stopSyncTimers();
  SYNC.pollTimer = setInterval(syncPoll, SYNC.POLL_MS);
}
function stopSyncTimers() {
  if (SYNC.pollTimer) { clearInterval(SYNC.pollTimer); SYNC.pollTimer = null; }
}
async function syncPoll() {
  if (S.modal || S.syncModal) return;
  if (SYNC.writeQueue.size > 0 || SYNC.writeTimer) return;
  if (SYNC.status === 'syncing' || SYNC.status === 'loading') return;
  try {
    SYNC.status = 'syncing'; renderTopbar();
    await graphReload();
    SYNC.status = 'connected'; SYNC.lastSyncAt = Date.now();
    render();
  } catch (e) {
    SYNC.status = 'error'; SYNC.errorMsg = e.message; renderTopbar();
  }
}

async function syncForceReload() {
  try {
    SYNC.status = 'syncing'; renderTopbar();
    await graphReload();
    SYNC.status = 'connected'; SYNC.lastSyncAt = Date.now();
    render();
    toast('Sincronizado com SharePoint.', 'ok');
  } catch (e) {
    SYNC.status = 'error'; SYNC.errorMsg = e.message; renderTopbar();
    toast('Erro ao sincronizar: ' + e.message, 'err');
