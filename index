    }).join('');
    const pr=DATES.filter(d=>getAtt(p.id,d)==='P').length;
    const ab=DATES.filter(d=>getAtt(p.id,d)==='F').length;
    const rate=(pr+ab)>0?Math.round(pr/(pr+ab)*100):null;
    return`<tr>
      <td style="white-space:nowrap;padding-right:8px">
        <div style="display:flex;align-items:center;gap:6px">
          <div class="av av-sm ${avCls(p)}">${ini(p.name)}</div>
          <span style="font-size:12px;font-weight:500">${esc(p.name)}</span>
          ${p.status==='Teste'?`<span class="badge b-purple" style="font-size:9px;padding:1px 5px">T</span>`:''}
        </div>
      </td>
      ${cells}
      <td style="white-space:nowrap;padding-left:8px">
        <span class="badge ${pr>0?'b-green':'b-gray'}">${pr}P</span>
        <span class="badge ${ab>0?'b-red':'b-gray'}" style="margin-left:3px">${ab}F</span>
        ${rate!==null?`<span style="font-size:11px;color:var(--text3);margin-left:4px">${rate}%</span>`:''}
      </td>
    </tr>`;
  }).join('');

  return`
    <div class="toolbar">
      <input type="text" id="search-presencas" placeholder="Pesquisar nome ou apelido (ex: 'Ana Silva', 'Sil')..." value="${esc(S.searchPres)}" oninput="S.searchPres=this.value;render()">
      ${S.searchPres?`<button class="btn btn-ghost btn-sm" onclick="S.searchPres='';render()" title="Limpar pesquisa"><i class="ti ti-x"></i> Limpar</button>`:''}
    </div>
    <div class="info-row">
      <span class="badge b-green">P</span> Presente &nbsp;
      <span class="badge b-red">F</span> Falta &nbsp;
      <span class="badge b-amber">D</span> Folga
      <span style="color:var(--text3)">— clique para alternar. Borda azul = hoje.</span>
      <span style="margin-left:auto;font-size:11px;color:var(--text3)">${S.searchPres?`${ap.length} de ${apAll.length}`:ap.length} pessoas · ${DATES.length} dias</span>
    </div>
    <div style="overflow-x:auto;border-radius:var(--radius-lg);border:1px solid var(--border)">
      <table style="min-width:800px">
        <thead><tr><th style="min-width:160px">Pessoa</th>${dH}<th style="min-width:90px">Resumo</th></tr></thead>
        <tbody>${ap.length?rows:`<tr><td colspan="${DATES.length+2}"><div class="empty"><i class="ti ti-user-off"></i>Nenhum colaborador encontrado para "${esc(S.searchPres)}".</div></td></tr>`}</tbody>
      </table>
    </div>`;
}

// ── ESCALA ──
function renderEscala(){
  const nom=nominal();const tst=emTeste();
  const totalWeeks=Math.ceil(DATES.length/7);
  const weekStart=S.weekIdx*7;const weekEnd=Math.min(weekStart+7,DATES.length);
  const weekDates=DATES.slice(weekStart,weekEnd);
  const wLabel=`${weekDates[0]} — ${weekDates[weekDates.length-1]}`;

  const dayCards=weekDates.map(d=>{
    const need=NEEDS[d]||0;const bal=nom.length-need;
    const balCls=bal<0?'b-red':bal<5?'b-amber':'b-green';
    const isToday=d===TODAY;
    const morning=nom.filter(p=>p.role!=='Turndown');
    const afternoon=nom.filter(p=>p.role==='Turndown'||p.role==='Valete');
    const personRow=p=>`<div class="shift-person"><div class="av av-sm ${avCls(p)}">${ini(p.name)}</div>${esc(p.name.split(' ').slice(0,2).join(' '))}</div>`;
    return`<div class="day-card ${isToday?'today':''}">
      <div class="day-card-header" onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display==='none'?'':'none'">
        <div style="display:flex;align-items:baseline;gap:2px">
          <span class="day-date">${d.slice(5)}</span>
          <span class="day-weekday">${dlFull(d)}</span>
          ${isToday?`<span class="badge b-blue" style="font-size:10px;margin-left:6px">Hoje</span>`:''}
        </div>
        <div class="day-badges">
          <span style="font-size:12px;color:var(--text3)">Need <b style="color:var(--text)">${need}</b></span>
          <span class="badge ${balCls}">${bal>0?'+':''}${bal}</span>
          ${tst.length>0?`<span class="badge b-purple">${tst.length}T</span>`:''}
          <i class="ti ti-chevron-down" style="font-size:14px;color:var(--text3)"></i>
        </div>
      </div>
      <div class="day-card-body">
        <div class="shift-block">
          <div class="shift-title" style="color:#185FA5"><i class="ti ti-sun"></i> Manhã 07:30</div>
          ${morning.length?morning.map(personRow).join(''):` <div style="font-size:11px;color:var(--text3)">—</div>`}
        </div>
        <div class="shift-block">
          <div class="shift-title" style="color:#854F0B"><i class="ti ti-moon"></i> Tarde 14:30</div>
          ${afternoon.length?afternoon.map(personRow).join(''):`<div style="font-size:11px;color:var(--text3)">—</div>`}
        </div>
        <div class="shift-block" style="border:1px solid #AFA9EC">
          <div class="shift-title" style="color:#534AB7"><i class="ti ti-flask"></i> Em Teste</div>
          ${tst.length?tst.map(p=>`<div class="shift-person"><div class="av av-sm av-teste">${ini(p.name)}</div><span>${esc(p.name.split(' ')[0])}</span><span class="badge b-purple" style="font-size:9px;margin-left:auto">${STEPS[p.testStep||0].slice(0,3)}</span></div>`).join(''):`<div style="font-size:11px;color:var(--text3)">—</div>`}
        </div>
      </div>
    </div>`;
  }).join('');

  return`
    <div class="escala-nav">
      <button class="btn btn-default btn-sm" onclick="S.weekIdx=Math.max(0,S.weekIdx-1);render()" ${S.weekIdx===0?'disabled':''}><i class="ti ti-chevron-left"></i> Anterior</button>
      <div class="week-label">${wLabel}</div>
      <button class="btn btn-default btn-sm" onclick="S.weekIdx=Math.min(${totalWeeks-1},S.weekIdx+1);render()" ${S.weekIdx>=totalWeeks-1?'disabled':''}>Seguinte <i class="ti ti-chevron-right"></i></button>
      <div style="margin-left:auto;display:flex;gap:4px">
        ${Array.from({length:totalWeeks},(_,i)=>`<button class="btn ${S.weekIdx===i?'btn-primary':'btn-default'} btn-xs" onclick="S.weekIdx=${i};render()">S${i+1}</button>`).join('')}
      </div>
    </div>
    ${dayCards}`;
}

// ── RESUMO ──
function renderResumo(){
  const ap=ativos();const nom=nominal();const tst=emTeste();
  const totalP=ap.reduce((a,p)=>a+DATES.filter(d=>getAtt(p.id,d)==='P').length,0);
  const totalF=ap.reduce((a,p)=>a+DATES.filter(d=>getAtt(p.id,d)==='F').length,0);
  const reg=totalP+totalF;const rate=reg>0?Math.round(totalP/reg*100):0;
  const worst=DATES.map(d=>({d,gap:(NEEDS[d]||0)-nom.length})).filter(x=>x.gap>0).sort((a,b)=>b.gap-a.gap).slice(0,5);
  const best=DATES.map(d=>({d,surplus:nom.length-(NEEDS[d]||0)})).filter(x=>x.surplus>=0).sort((a,b)=>b.surplus-a.surplus).slice(0,3);

  return`
    <div class="metrics">
      <div class="metric"><div class="metric-label">Ativos</div><div class="metric-val">${ap.length}</div></div>
      <div class="metric"><div class="metric-label">Nominais</div><div class="metric-val m-green">${nom.length}</div></div>
      <div class="metric"><div class="metric-label">Em Teste</div><div class="metric-val m-purple">${tst.length}</div></div>
      <div class="metric"><div class="metric-label">Taxa presença</div><div class="metric-val ${rate>=80?'m-green':rate>=60?'m-amber':'m-red'}">${rate}%</div></div>
      <div class="metric"><div class="metric-label">Presenças reg.</div><div class="metric-val m-green">${totalP}</div></div>
      <div class="metric"><div class="metric-label">Faltas reg.</div><div class="metric-val m-red">${totalF}</div></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:20px">
      <div>
        <div class="section-hd">Por empresa</div>
        ${COMPANIES.map(co=>{const n=ap.filter(p=>p.company===co).length;const pct=ap.length?Math.round(n/ap.length*100):0;const col=co==='Timing'?'#378ADD':co==='Serlima'?'#D85A30':'#1D9E75';return`<div style="margin-bottom:8px"><div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:3px"><span style="font-weight:500">${co}</span><span style="color:var(--text3)">${n} (${pct}%)</span></div><div class="progress-bar"><div class="progress-fill" style="width:${pct}%;background:${col}"></div></div></div>`;}).join('')}
      </div>
      <div>
        <div class="section-hd">Etapas de teste</div>
        ${tst.length===0?`<div style="font-size:13px;color:var(--text3)">Sem pessoas em teste.</div>`:STEPS.map((s,i)=>{const n=tst.filter(p=>(p.testStep||0)===i).length;return`<div style="margin-bottom:8px;display:flex;justify-content:space-between;align-items:center"><span style="font-size:13px;font-weight:500">${s}</span><span class="badge b-purple">${n}</span></div>`;}).join('')}
      </div>
      <div>
        <div class="section-hd">Dias com folga suficiente</div>
        ${best.length===0?`<div style="font-size:12px;color:var(--text3)">—</div>`:best.map(x=>`<div style="margin-bottom:6px;display:flex;justify-content:space-between;font-size:12px"><span>${x.d} (${dl(x.d)})</span><span class="badge b-green">+${x.surplus}</span></div>`).join('')}
      </div>
    </div>
    ${tst.length>0?`<div class="section-hd">Pessoas em teste</div>
    <div class="table-wrap" style="margin-bottom:20px"><table><thead><tr><th>Nome</th><th>Empresa</th><th>Etapa</th><th>Progresso</th><th>Início</th></tr></thead><tbody>
      ${tst.map(p=>`<tr><td style="font-weight:500">${esc(p.name)}</td><td><span class="badge ${coCls(p.company)}">${p.company}</span></td><td><span class="badge b-purple">${STEPS[p.testStep||0]}</span></td><td>${dots(p.testStep||0)}</td><td style="font-size:12px;color:var(--text3)">${p.testStartDate||'—'}</td></tr>`).join('')}
    </tbody></table></div>`:''}
    <div class="section-hd">Dias críticos (necessidade > nominais)</div>
    ${worst.length===0?`<div style="font-size:13px;color:var(--text3);padding:8px 0">Sem dias críticos com o grupo atual. ✓</div>`:
    `<div class="table-wrap"><table><thead><tr><th>Data</th><th>Dia</th><th>Necessidade</th><th>Nominais</th><th>Gap</th></tr></thead><tbody>
      ${worst.map(x=>`<tr><td style="font-weight:500">${x.d}</td><td>${dlFull(x.d)}</td><td>${NEEDS[x.d]}</td><td>${nom.length}</td><td><span class="badge b-red">−${x.gap}</span></td></tr>`).join('')}
    </tbody></table></div>`}`;
}

// ── SYNC MODAL ──
function syncModalRender(){
  if(!S.syncModal) return '';
  const st=SYNC.status;
  const since = SYNC.lastSyncAt ? new Date(SYNC.lastSyncAt).toLocaleTimeString('pt-PT') : '—';
  return`<div class="overlay" onclick="closeSyncModal()"><div class="modal" onclick="event.stopPropagation()">
    <div class="mhead">
      <h3><i class="ti ti-brand-microsoft" style="color:var(--blue);font-size:18px"></i> Sincronização SharePoint</h3>
      <button class="btn btn-ghost btn-icon" onclick="closeSyncModal()" aria-label="Fechar"><i class="ti ti-x"></i></button>
    </div>
    <div class="mbody">
      <div class="info-row" style="margin-bottom:14px;flex-direction:column;align-items:flex-start;gap:4px">
        <div style="display:flex;gap:8px;align-items:center"><i class="ti ti-user" style="color:var(--blue)"></i> <span><b>Sessão:</b> ${esc(SYNC.user?.name||'—')}</span></div>
        <div style="display:flex;gap:8px;align-items:center"><i class="ti ti-mail" style="color:var(--text3)"></i> <span style="color:var(--text2);font-size:11px">${esc(SYNC.user?.mail||'')}</span></div>
        <div style="display:flex;gap:8px;align-items:center"><i class="ti ti-cloud-check" style="color:var(--green)"></i> <span><b>Site:</b> ${esc(GRAPH.sitePath)} (${esc(GRAPH.siteHostname)})</span></div>
        <div style="display:flex;gap:8px;align-items:center"><i class="ti ti-list" style="color:var(--text3)"></i> <span style="font-size:11px;color:var(--text2)">Listas: ${esc(GRAPH.listPessoas)} · ${esc(GRAPH.listPresencas)}</span></div>
        <div style="display:flex;gap:8px;align-items:center"><i class="ti ti-clock" style="color:var(--text3)"></i> <span style="font-size:11px;color:var(--text3)">Última sincronização: ${since}</span></div>
      </div>
      <div style="font-size:12px;color:var(--text2);margin-bottom:14px;line-height:1.5">
        Os dados estão guardados no SharePoint da empresa. Cada alteração é gravada automaticamente (~1.2s após a última edição). O painel verifica novas alterações de outros utilizadores a cada 15 segundos.
      </div>
      ${st==='error'?`<div class="info-row" style="background:var(--red-bg);color:#791F1F;border:1px solid #F09595">
        <i class="ti ti-alert-circle" style="color:var(--red)"></i> <span>${esc(SYNC.errorMsg||'Erro de sincronização.')}</span>
      </div>`:''}
      <hr class="sep">
      <div class="section-hd" style="margin-top:0">Ações</div>
      <div style="display:flex;gap:6px;flex-wrap:wrap">
        <button class="btn btn-default btn-sm" onclick="syncForceReload()"><i class="ti ti-refresh"></i> Sincronizar agora</button>
        <button class="btn btn-default btn-sm" onclick="exportJSON()"><i class="ti ti-download"></i> Backup JSON</button>
        <button class="btn btn-red btn-sm" onclick="authLogout()"><i class="ti ti-logout"></i> Terminar sessão</button>
      </div>
    </div>
    <div class="mfoot">
      <button class="btn btn-default btn-sm" onclick="closeSyncModal()">Fechar</button>
    </div>
  </div></div>`;
}

// ── TOPBAR ──
function renderTopbar(){
  const st=SYNC.status;
  const cfg={
    disconnected:{bg:'var(--bg3)',col:'var(--text3)',ic:'ti-cloud-off',lbl:'Desligado'},
    loading:{bg:'var(--blue-bg)',col:'#0C447C',ic:'ti-cloud-upload',lbl:'A carregar…'},
    connected:{bg:'var(--green-bg)',col:'#27500A',ic:'ti-cloud-check',lbl:'SharePoint'},
    syncing:{bg:'var(--blue-bg)',col:'#0C447C',ic:'ti-cloud-upload',lbl:'A sincronizar…'},
    error:{bg:'var(--red-bg)',col:'#791F1F',ic:'ti-cloud-x',lbl:'Erro'}
  }[st]||{bg:'var(--bg3)',col:'var(--text3)',ic:'ti-cloud-off',lbl:st};
  const userInit = SYNC.user?.name ? SYNC.user.name.split(' ').slice(0,2).map(s=>s[0]).join('').toUpperCase() : '?';
  const el = document.getElementById('topbar-actions');
  if (!el) return;
  el.innerHTML=`
    <button class="btn btn-sm" onclick="openSyncModal()" title="${esc(SYNC.user?.mail||'')}" style="background:${cfg.bg};color:${cfg.col};border-color:transparent"><i class="ti ${cfg.ic}"></i> <span>${esc(cfg.lbl)}</span></button>
    <button class="btn btn-default btn-sm" onclick="buildExcel()" title="Exportar Excel"><i class="ti ti-file-spreadsheet" style="color:#217346"></i> Excel</button>
    <button class="btn btn-ghost btn-sm" onclick="openSyncModal()" title="${esc(SYNC.user?.name||'Sessão')}" style="background:var(--blue);color:#fff;width:30px;height:28px;padding:0;border-radius:50%;font-size:11px;font-weight:600;justify-content:center">${esc(userInit)}</button>
  `;
}

// ── MAIN RENDER ──
function render(){
  const root=document.getElementById('root');
  // Preservar foco e posição do cursor entre renders (importante para inputs de pesquisa)
  const ae=document.activeElement;
  const aeId=ae&&ae.id?ae.id:null;
  const selStart=ae&&'selectionStart'in ae?ae.selectionStart:null;
  const selEnd=ae&&'selectionEnd'in ae?ae.selectionEnd:null;

  let content='';
  if(S.tab==='pessoas') content=renderPessoas();
  else if(S.tab==='presencas') content=renderPresencas();
  else if(S.tab==='escala') content=renderEscala();
  else if(S.tab==='resumo') content=renderResumo();

  root.innerHTML=`
    ${!S.hasSaved?`<div class="no-saved"><i class="ti ti-info-circle"></i> Dados iniciais carregados. As alterações são guardadas automaticamente no browser.<div class="storage-btns"><button class="btn btn-amber btn-xs" onclick="S.hasSaved=true;saveState();render()"><i class="ti ti-check"></i> OK</button></div></div>`:''}
    <div class="tabs">${tabs()}</div>
    ${S.tab!=='escala'?exportBar():''}
    ${content}
    ${modal()}
    ${syncModalRender()}`;
  renderTopbar();

  // Restaurar foco
  if(aeId){
    const el=document.getElementById(aeId);
    if(el){
      el.focus();
      if(selStart!==null&&'setSelectionRange'in el){
        try{el.setSelectionRange(selStart,selEnd);}catch(e){}
      }
    }
  }
}

// ── KEYBOARD ──
document.addEventListener('keydown',e=>{if(e.key==='Escape'){if(S.modal)closeModal();else if(S.syncModal)closeSyncModal()}});

// ── GLOBALS ──
window.openAdd=openAdd;window.openEdit=openEdit;window.closeModal=closeModal;window.save=save;
window.del=del;window.advStep=advStep;window.conclude=conclude;window.cycleAtt=cycleAtt;
window.setSort=setSort;window.buildExcel=buildExcel;window.clearState=clearState;
window.patchModal=patchModal;
window.toggleCap=c=>{const i=S.form.caps.indexOf(c);if(i>=0)S.form.caps.splice(i,1);else S.form.caps.push(c);patchModal()};
// Sync globals
window.openSyncModal=openSyncModal;window.closeSyncModal=closeSyncModal;
window.syncForceReload=syncForceReload;window.authLogout=authLogout;
window.exportJSON=exportJSON;

// Arranque: autenticar e carregar dados antes de mostrar a app
authStart();
</script>
</body>
</html>
